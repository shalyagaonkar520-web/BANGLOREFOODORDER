{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A food or grocery item available for order.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the item" },
        "price": { "type": "number", "description": "Price of the item" },
        "image": { "type": "string", "description": "URL of the item image" },
        "category": { "type": "string", "description": "Category (e.g., Pizza, Fruits)" },
        "type": { "type": "string", "enum": ["food", "grocery"], "description": "Type of delivery" },
        "description": { "type": "string", "description": "Short description of the item" }
      },
      "required": ["name", "price", "image", "category", "type"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "object" }
        },
        "total": { "type": "number" },
        "type": { "type": "string", "enum": ["food", "grocery"] },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "phone", "address", "items", "total", "type", "createdAt"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of available products"
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of customer orders"
    }
  }
}
